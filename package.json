{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start:dev": "tsx --env-file=.env src/server.ts",
    "start:watch": "tsx watch --env-file=.env src/server.ts",
    "dist": "tsup src/server.ts --out-dir dist",
    "start:dist": "npm run dist && node dist/server.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
